{
    "name": "@soliantconsulting/fm-saxml-delivery",
    "version": "0.0.0-managed-by-semantic-release",
    "description": "Download a filemaker container file after running a script.",
    "files": [
        "dist/**/*"
    ],
    "bin": {
        "fm-saxml-delivery": "./dist/cli.js"
    },
    "main": "index.js",
    "type": "module",
    "module": "es2022",
    "scripts": {
        "start": "tsx ./src/cli.ts",
        "build": "tsc",
        "format": "biome format . --write",
        "check": "biome check . --write"
    },
    "author": "Soliant Consulting",
    "license": "MIT",
    "devDependencies": {
        "@biomejs/biome": "^2.1.1",
        "@tsconfig/node22": "^22.0.5",
        "@types/node": "^22.19.21",
        "tsx": "^4.22.4",
        "typescript": "~5.9.2"
    },
    "dependencies": {
        "dotenv": "^17.0.1",
        "fm-data-api-client": "^3.0.0"
    },
    "release": {
        "branches": [
            "main"
        ]
    },
    "publishConfig": {
        "access": "public"
    },
    "engines": {
        "node": ">=20"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/soliantconsulting/fm-saxml-delivery"
    }
}
